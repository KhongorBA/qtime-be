PORT=5000
DATABASE_URL="postgresql://qtime:Xe3M4zrOvkpdhii4@localhost:5432/bookez?schema=public"
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# CORS allowlist (comma-separated). Example:
# CORS_ORIGIN=http://localhost:3000,http://localhost:50065
# If empty, all origins are allowed (dev only).
# CORS_ORIGIN=

# HttpOnly auth cookie config
# AUTH_COOKIE_NAME=bookez_at
# COOKIE_SECURE=true          # true in production (HTTPS)
# COOKIE_SAME_SITE=none       # none for cross-site cookie
# COOKIE_DOMAIN=.yourdomain.com

# Login: use RSA-encrypted credentials (default: true)
# AUTH_USE_CIPHER=false  # set to disable cipher, accept plain password

# Forgot password: return reset token in response for dev/testing (default: false)
# FORGOT_PASSWORD_RETURN_TOKEN=true

# Optional: persist RSA keys (generate with: openssl genrsa -out private.pem 2048)
# RSA_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# FCM: Bookez (хэрэглэгчийн апп) — service account JSON зам
# FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# Booker-Business апп өөр Firebase төсөл ашиглавал (жишээ нь booker-business-cc63e):
# FIREBASE_BUSINESS_SERVICE_ACCOUNT_PATH=./booker-business-firebase-adminsdk.json

# QPay (Mongolian QR payment — 13 banks supported)
# Sandbox:    QPAY_BASE_URL=https://sandbox.qpay.mn/v2
# Production: QPAY_BASE_URL=https://merchant.qpay.mn/v2
# QPAY_BASE_URL=https://sandbox.qpay.mn/v2
# QPAY_USERNAME=your_merchant_username
# QPAY_PASSWORD=your_merchant_password
# QPAY_INVOICE_CODE=BOOKEZ_INVOICE
#
# Mock mode (no real API calls — logs to console, auto-pays after 10s):
# QPAY_MOCK=true
#
# Your server's public URL (used for QPay webhook callback)
# API_BASE_URL=https://your-domain.com
#
# Webhook secret — random string, нэмэгдэх callback URL-д ?secret=... болно.
# QPay манай webhook-г дуудахад энэ secret байхгүй бол 403 буцаана.
# Генерэх: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# QPAY_WEBHOOK_SECRET=change_me_random_32_chars

# Email OTP (Nodemailer SMTP)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="Bookez" <noreply@bookez.mn>
