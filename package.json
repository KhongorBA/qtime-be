{
  "name": "qtime-be",
  "version": "1.0.0",
  "description": "Backend for Fresha-like booking platform - salons, spas, barbers & beauty services",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "notification:test": "node scripts/insert-test-notification.js",
    "receipt-fonts": "node scripts/download-receipt-fonts.mjs"
  },
  "keywords": [
    "booking",
    "salon",
    "spa",
    "fresha",
    "appointments"
  ],
  "license": "MIT",
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "express-rate-limit": "^8.3.2",
    "express-validator": "^7.2.0",
    "firebase-admin": "^13.0.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.18.0"
  },
  "devDependencies": {
    "prisma": "^5.22.0"
  }
}
